---
import type { StyledProps } from "@/types";

import IndexList from "./IndexList.astro";

import { indexType } from "@/consts";

interface Props extends StyledProps {}

const { class: className = "", style: styleAttr = "" } = Astro.props;
---

<IndexList
  class={className}
  style={styleAttr}
  type={indexType.Tags}
  title="Tags"
  listClass="flex flex-wrap gap-1"
  linkClass="btn px-2 text-xs"
/>
