---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";

import MainLayout from "@/layouts/MainLayout.astro";
import Decorator from "@/components/common/Decorator.astro";
import Link from "@/components/common/Link.astro";
import ArchivePostList from "@/components/post/ArchivePostList.astro";
import { indexType, siteConfig } from "@/consts";
import { createRouteUrl } from "@/lib/utils";

export const getStaticPaths = (async () => {
  const indexes = await getCollection("postIndex");
  return indexes.map((index) => ({
    params: { index: index.id },
    props: { index },
  }));
}) satisfies GetStaticPaths;

const typeMeta = {
  [indexType.PublishedYear]: { label: "Years", eyebrow: "Timeline" },
  [indexType.Categories]: { label: "Categories", eyebrow: "Topics" },
  [indexType.Tags]: { label: "Tags", eyebrow: "Keywords" },
  [indexType.Series]: { label: "Series", eyebrow: "Threads" },
} as const;

const sortPostsByPublished = <
  T extends { data: { published: Date; title: string } },
>(
  posts: T[],
) =>
  [...posts].sort((a, b) => {
    const compare =
      +new Date(b.data.published ?? 0) - +new Date(a.data.published ?? 0);
    return compare !== 0
      ? compare
      : (a.data.title ?? "").localeCompare(b.data.title ?? "");
  });

const { index } = Astro.props;
const posts = sortPostsByPublished(
  await getCollection(
    "posts",
    (post) => !post.data.draft && index.data.items.includes(post.id),
  ),
);
const meta = typeMeta[index.data.type];
---

<MainLayout
  seo={{
    title: index.data.name,
    description: `${siteConfig.title} posts for ${index.data.name}.`,
    type: "website",
  }}
>
  <div class="anim-delay-sequence space-y-2">
    <section class="card anim-onload p-5 sm:p-6" style="--i: 0">
      <div class="flex items-center justify-between gap-3">
        <div class="space-y-1">
          <Decorator
            class="text-foreground/55 text-xs tracking-[0.24em] uppercase"
          >
            {meta.label}
          </Decorator>
          <div
            class="text-foreground/55 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm"
          >
            <span class="text-foreground/75">{index.data.name}</span>
            <span class="text-foreground/25">/</span>
            <span>{posts.length} posts</span>
          </div>
        </div>
        <Link
          class="text-foreground/65 hover:text-accent text-sm transition-colors"
          href={createRouteUrl("index", index.data.type)}
        >
          Back to {meta.label.toLowerCase()}
        </Link>
      </div>
    </section>

    <section class="anim-onload space-y-2" style="--i: 1">
      <div class="card p-4 sm:p-5">
        <ArchivePostList posts={posts} />
      </div>
    </section>
  </div>

  <div slot="right-aside" class="anim-delay-sequence space-y-2">
    <div class="card anim-onload space-y-3 p-4" style="--i: 0">
      <Decorator class="text-sm font-medium">Group</Decorator>
      <div class="space-y-1">
        <p class="text-foreground text-sm font-medium">{index.data.name}</p>
        <p class="text-foreground/55 text-sm">{meta.eyebrow}</p>
      </div>
      <div class="text-foreground/55 space-y-1 text-sm">
        <p>{posts.length} posts</p>
        <p>{index.data.type}</p>
      </div>
    </div>

    <div class="card anim-onload space-y-3 p-4" style="--i: 1">
      <Decorator class="text-sm font-medium">Back</Decorator>
      <div class="space-y-1.5">
        <Link
          class="btn justify-between px-3 text-sm"
          data-variant="ghost"
          href={createRouteUrl("index", index.data.type)}
        >
          <span>{meta.label}</span>
          <span class="text-foreground/45 text-xs">axis</span>
        </Link>
        <Link
          class="btn justify-between px-3 text-sm"
          data-variant="ghost"
          href={createRouteUrl("index")}
        >
          <span>Archive</span>
          <span class="text-foreground/45 text-xs">root</span>
        </Link>
      </div>
    </div>
  </div>
</MainLayout>
