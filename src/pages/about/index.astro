---
import AuthorProfile from "@/components/ui/AuthorProfile.astro";
import { routes, siteConfig } from "@/consts";
import MainLayout from "@/layouts/MainLayout.astro";
---

<MainLayout
  seo={{
    title: "About",
    description: `${siteConfig.authorName} and ${siteConfig.title} profile page.`,
    type: "website",
  }}
>
  <div class="card px-6 py-4">
    <h1 class="text-lg font-bold">{routes.about.label}</h1>
  </div>
  <AuthorProfile class="anim-onload" style="--i: 1" />
</MainLayout>
