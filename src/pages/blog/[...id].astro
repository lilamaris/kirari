---
import type { GetStaticPaths } from "astro";
import { render, getCollection } from "astro:content";

import MainLayout from "@/layouts/MainLayout.astro";
import TableOfContents from "@/components/post/TableOfContents.astro";
import PostHeader from "@/components/post/PostHeader.astro";
import PostNavigation from "@/components/post/PostNavigation.astro";
import { themeConfig } from "@/consts";

export const getStaticPaths = (async () => {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { olderPostRef, newerPostRef } = post.data;
const { thumbnailFallbackImgUrl } = themeConfig;
---

<MainLayout
  seo={{
    title: post.data.title,
    description: post.data.description,
    image: post.data.image?.src ?? thumbnailFallbackImgUrl,
    type: "article",
    publishedTime: post.data.published,
    keywords: post.data.tags,
  }}
>
  <div class="anim-delay-sequence space-y-2">
    <PostNavigation
      class="anim-onload"
      style="--i: 0"
      olderPostRef={olderPostRef}
      newerPostRef={newerPostRef}
    />
    <div class="card anim-onload space-y-2 p-4" style="--i: 1">
      <PostHeader post={post} class="anim-onload" />
      <div
        class="border-border rounded-surface my-4 h-1 w-full translate-y-1 border-b-4 border-dashed"
      >
      </div>
      <article
        class="anim-onload prose px-6 xl:max-w-[var(--contentWidth)]"
        style="--i: 2"
      >
        <Content />
      </article>
    </div>

    <PostNavigation
      class="anim-onload"
      style="--i: 3"
      olderPostRef={olderPostRef}
      newerPostRef={newerPostRef}
    />
  </div>
  <TableOfContents
    headings={headings}
    class:list={["max-h-[40dvh] mask-y-from-95%"]}
    slot="right-aside"
  />
</MainLayout>
